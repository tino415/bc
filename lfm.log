    document.onmousemove = function(e) {
        var event = e || window.event,
            clientY = event.clientY,
            lineFound = false,
            hoverLines = Sizzle('.hover-line');

        for (var i = 0, imax = codeBlocks.length - 1; i < imax; ++i) {
